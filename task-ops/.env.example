# PostgreSQL（本地开发）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taskops?schema=public"
# 部署到 Neon / Supabase 等时通常需要 ssl，例如：
# DATABASE_URL="postgresql://user:pass@host.region.provider.com/db?sslmode=require"

# NextAuth — generate: openssl rand -base64 32（生产环境必须设置）
AUTH_SECRET="change-me-in-production-use-long-random-string"
# 兼容旧变量名
# NEXTAUTH_SECRET="same-as-above"

# 站点根地址（本地 / 生产必须与实际访问 URL 一致）
AUTH_URL="http://localhost:3000"
# 部署到 Vercel 等时改为公网地址，例如：
# AUTH_URL="https://your-app.vercel.app"

# Optional: OpenAI-compatible API for AI reports (leave empty to use rule-based mock analysis)
# OPENAI_API_KEY=""
# OPENAI_BASE_URL="https://api.openai.com/v1"
